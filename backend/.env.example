# Application configuration
APP_NAME="SBOM Analyzer"
APP_ENV=development
APP_DEBUG=true
PORT=5000
SECRET_KEY=super_secret_app_key_change_in_production

# Database Settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=sbom_user
DB_PASSWORD=sbom_password
DB_NAME=sbom_analyzer_db
DATABASE_URL=mysql+mysqlconnector://sbom_user:sbom_password@127.0.0.1:3306/sbom_analyzer_db

# Security & JWT Tokens
JWT_SECRET=jwt_token_signing_secret_change_in_production
JWT_EXPIRATION_HOURS=24

# External Security Intelligence & AI Credentials
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo

# Storage limits
MAX_CONTENT_LENGTH_MB=25
UPLOAD_FOLDER=uploads

# Log System Level
LOG_LEVEL=DEBUG
